options {
    directory "/var/cache/bind";

    listen-on { 127.0.0.1; 192.168.1.10; any; };
    listen-on-v6 { none; };

    allow-query     { 127.0.0.1; 192.168.1.0/24; };
    allow-recursion { none; };
    recursion no;

    allow-transfer  { none; };

    dnssec-validation no;

    forwarders { };
};
