zone "isc2boulder.ctf" {
    type master;
    file "/var/lib/bind/db.isc2boulder.ctf";
    allow-query { 192.168.1.0/24; 127.0.0.1; };
};

zone "tastybytes.ctf" {
    type master;
    file "/var/lib/bind/db.tastybytes.ctf";
    allow-query { 192.168.1.0/24; 127.0.0.1; };
};

zone "1.168.192.in-addr.arpa" {
    type master;
    file "/var/lib/bind/db.192.168.1";
    allow-query { 192.168.1.0/24; 127.0.0.1; };
};